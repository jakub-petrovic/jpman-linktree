{
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/qr",
            "destination": "/tools/qr"
            
        }
    ],
    "redirects":[
        {
            "source": "/t",
            "destination": "/tools/",
            "permanent":true
        },
        {
            "source": "/t/:page*",
            "destination": "/tools/:page*",
            "permanent":true
        }
    ]
}
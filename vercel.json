{
    "rewrites": [
        {
            "source": "/qr",
            "destination": "/tools/qr.html",
            "permanent": true
        }
    ],
    "redirects": [
        {
            "source": "/t",
            "destination": "/tools/index.html",
            "permanent": true
        },
        {
            "source": "/t/:page",
            "destination": "/tools/:page.html",
            "permanent": true
        }
    ]
}